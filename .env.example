# =============================================================================
# Voice Agent - Environment Variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example.com  # Twilio needs a public URL
LOG_LEVEL=INFO

# --- Twilio (telephony) ---
# Get from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567
# Optional: PIN-protect the webhook with this shared secret.
TWILIO_WEBHOOK_AUTH_TOKEN=

# =============================================================================
# AI Providers — Pick ONE stack. Bailian (百炼) is recommended for mainland
# China; Deepgram + OpenAI is the alternative international stack.
# =============================================================================

# ---------- Stack A: Alibaba Bailian (百炼) — RECOMMENDED ----------
# 阿里云百炼 · 一站式 LLM + STT + TTS
# Get a key from https://bailian.console.aliyun.com/
# 开通模型：通义千问 (LLM) + Paraformer/FunASR (ASR) + CosyVoice (TTS)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM: Qwen series. Set LLM_MODEL to one of:
#   qwen-turbo       · fast, cheap
#   qwen-plus        · balanced
#   qwen-max         · top quality
#   qwen3-omni-flash · multimodal (audio in / audio out)
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# STT: FunASR streaming (telephony-grade Chinese)
BAILIAN_STT_MODEL=funasr-realtime
# TTS: CosyVoice (拟人级中文)
BAILIAN_TTS_MODEL=cosyvoice-v1
# CosyVoice voices (女/男声):
#   longxiaochun    · 龙小淳 女声 (默认推荐)
#   longxiaobai     · 龙小白 女声
#   longxiaoxia     · 龙小夏 女声
#   longcheng       · 龙橙 男声
#   longhua         · 龙华 男声
#   longjing        · 龙靖 男声
BAILIAN_TTS_VOICE=longxiaochun

# ---------- Stack B: Deepgram + OpenAI (international) ----------
# DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# OPENAI_TTS_VOICE=nova
# OPENAI_TTS_MODEL=tts-1

# =============================================================================

# --- WeChat Work (企业微信) Webhook ---
# Create a group robot in WeChat Work group, copy the webhook URL.
# Pattern: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WECHAT_WEBHOOK_URL=

# --- Visitor database (SQLite) ---
DATABASE_URL=sqlite+aiosqlite:///./data/visitors.db

# --- Park config ---
PARK_NAME=蓝色鲸鱼科技园
DEFAULT_COMPANY=蓝色鲸鱼科技
GUARD_GROUP_NAME=园区门卫通知群

