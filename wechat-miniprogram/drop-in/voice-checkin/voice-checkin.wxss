/* pages/voice-checkin/voice-checkin.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0f1115;
  color: #e6e8eb;
  padding: 24rpx;
  box-sizing: border-box;
}
.header { text-align: center; margin-bottom: 16rpx; }
.title { display: block; font-size: 40rpx; font-weight: 600; }
.subtitle { display: block; font-size: 24rpx; color: #8b95a7; margin-top: 6rpx; }

.status-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 24rpx; background: #1a1d24;
  border: 1rpx solid #2a2f3a; border-radius: 16rpx; margin-bottom: 24rpx;
}
.status-dot.on { color: #3ecf8e; }
.status-dot.off { color: #8b95a7; }
.status-text { font-size: 26rpx; color: #cbd2dc; }

.controls { display: flex; justify-content: center; margin-bottom: 24rpx; }
.mic-btn {
  width: 280rpx; height: 280rpx; border-radius: 50%;
  background: #4f8cff; color: #fff; display: flex; flex-direction: column;
  align-items: center; justify-content: center; border: none;
  box-shadow: 0 12rpx 30rpx rgba(79, 140, 255, 0.4);
  transition: transform 0.1s ease, background 0.15s ease;
}
.mic-btn.recording {
  background: #c14545; box-shadow: 0 12rpx 30rpx rgba(193, 69, 69, 0.4);
  animation: pulse 1.2s ease-in-out infinite;
}
.mic-btn[disabled] { background: #555; box-shadow: none; opacity: 0.6; }
.mic-icon { font-size: 72rpx; line-height: 1; }
.mic-text { font-size: 24rpx; margin-top: 12rpx; }
@keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }

.log-panel {
  flex: 1; display: flex; flex-direction: column;
  background: #1a1d24; border: 1rpx solid #2a2f3a; border-radius: 16rpx;
  overflow: hidden; min-height: 0;
}
.log-title {
  padding: 12rpx 24rpx; font-size: 22rpx; color: #8b95a7;
  text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1rpx solid #2a2f3a;
}
.log { flex: 1; padding: 16rpx 16rpx 32rpx; box-sizing: border-box; overflow-y: auto; }
.bubble-row { display: flex; margin: 8rpx 0; }
.bubble-row.user { justify-content: flex-end; }
.bubble-row.agent { justify-content: flex-start; }
.bubble-row.sys { justify-content: center; }
.bubble {
  max-width: 80%; padding: 12rpx 20rpx; border-radius: 16rpx;
  font-size: 28rpx; line-height: 1.4; word-break: break-word;
}
.bubble.user { background: rgba(62, 207, 142, 0.15); border: 1rpx solid #3ecf8e; }
.bubble.agent { background: rgba(255, 184, 77, 0.12); border: 1rpx solid #ffb84d; }
.bubble.sys {
  background: rgba(139, 149, 167, 0.12); border: 1rpx solid #8b95a7;
  color: #8b95a7; font-size: 22rpx;
}
.empty { text-align: center; color: #8b95a7; font-size: 24rpx; padding: 40rpx 0; }

.meta { text-align: center; font-size: 20rpx; color: #8b95a7; margin-top: 12rpx; }
